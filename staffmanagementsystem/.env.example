# Frontend Configuration
VITE_API_BASE_URL=http://localhost:5098/api
VITE_API_TIMEOUT=30000

# Development Settings
VITE_ENABLE_LOGGING=true
VITE_ENABLE_DEBUG_MODE=true

# Authentication Configuration
